# Local dev default: SQLite file, no setup needed.
# To use PostgreSQL instead, set e.g.:
# DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5432/bbmt_membership
DATABASE_URL=sqlite:///./bbmt_membership.db
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
CORS_ORIGINS=http://localhost:5173
